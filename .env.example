# Echo-OSINT Environment Variables
# Copy this file to .env and fill in your values

# NVIDIA NIM API (Get free key at https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Reddit (Optional - works without auth with lower rate limits)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=Echo-OSINT/0.1
REDDIT_SUBREDDITS=technology,programming,artificial,MachineLearning
REDDIT_ENABLED=true

# GitHub (Get token at https://github.com/settings/tokens)
GITHUB_TOKEN=your_github_token_here
GITHUB_ENABLED=true

# HackerNews (No auth required)
HN_ENABLED=true

# YouTube (Optional - requires API key from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_ENABLED=false

# SearXNG (Self-hosted or public instance)
SEARXNG_URL=http://localhost:8080
SEARXNG_ENABLED=true

# RSS Feeds (Comma-separated URLs)
RSS_FEEDS=

# Vector Database (Qdrant - optional, for advanced knowledge base)
QDRANT_URL=localhost:6333
QDRANT_API_KEY=your_qdrant_api_key

# Graph Database (Neo4j - optional, for knowledge graphs)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Research Configuration
CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=3
PARALLEL_SOURCES=5
RESEARCH_TIMEOUT=120000

# CrewAI Process
CREWAI_PROCESS=hierarchical